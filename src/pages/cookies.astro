---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const cookies = [
    {
        name: "_ga",
        type: "Non-necessary",
        duration: "2 Jahre",
        desc: "Google Analytics",
    },
    {
        name: "_gat_gtag_UA_151410239_1",
        type: "Non-necessary",
        duration: "2 Jahre",
        desc: "Google Analytics",
    },
    {
        name: "_gid",
        type: "Non-necessary",
        duration: "2 Jahre",
        desc: "Google Analytics",
    },
    {
        name: "cookielawinfo-checkbox-necessary",
        type: "Notwendig",
        duration: "1 Jahr",
        desc: "Speichert den Zustand der Cookie-Einstellung",
    },
    {
        name: "cookielawinfo-checkbox-non-necessary",
        type: "Notwendig",
        duration: "1 Jahr",
        desc: "Speichert den Zustand der Cookie-Einstellung",
    },
    {
        name: "PHPSESSID",
        type: "Notwendig",
        duration: "Session",
        desc: "Temporärer Session-Cookie",
    },
    {
        name: "viewed_cookie_policy",
        type: "Notwendig",
        duration: "1 Jahr",
        desc: "Speichert den Zustand der Cookie-Einstellung",
    },
];
---

<BaseLayout
    title="depero GmbH - Cookies"
    description="Cookie-Richtlinie der depero GmbH. Informationen über die von uns verwendeten Cookies."
>
    <main>
        <PageHero
            title="Cookies"
            background="linear-gradient(300deg, #fcdbcf, #d4f4e9)"
        />

        <section class="section-padding">
            <div class="container content-width">
                <p class="intro-text">
                    Wir verwenden Cookies, um Ihnen den bestmöglichen Service zu
                    gewährleisten. Mit der Nutzung der Webseite stimmen Sie der
                    Verwendung von Cookies zu.
                </p>

                <h2 class="section-heading">Verwendete Cookies</h2>

                <div class="table-wrap">
                    <table class="cookie-table">
                        <thead>
                            <tr>
                                <th>Cookie</th>
                                <th>Typ</th>
                                <th>Dauer</th>
                                <th>Beschreibung</th>
                            </tr>
                        </thead>
                        <tbody>
                            {
                                cookies.map((c) => (
                                    <tr>
                                        <td>
                                            <code>{c.name}</code>
                                        </td>
                                        <td>{c.type}</td>
                                        <td>{c.duration}</td>
                                        <td>{c.desc}</td>
                                    </tr>
                                ))
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    .content-width {
        max-width: 900px;
        margin: 0 auto;
    }

    .intro-text {
        font-size: var(--fs-body);
        line-height: 1.7;
        color: #444;
        margin-bottom: 40px;
    }

    .section-heading {
        font-size: var(--fs-heading-2);
        margin-bottom: 20px;
        color: var(--dark);
    }

    .table-wrap {
        overflow-x: auto;
    }

    .cookie-table {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--fs-small);
    }

    .cookie-table th,
    .cookie-table td {
        text-align: left;
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
    }

    .cookie-table th {
        background: var(--light-bg);
        font-weight: 600;
        color: var(--dark);
    }

    .cookie-table td {
        color: #555;
    }

    .cookie-table code {
        font-size: var(--fs-small);
        background: var(--light-bg);
        padding: 2px 6px;
        border-radius: 4px;
    }

    .cookie-table tbody tr:hover {
        background: #fafafa;
    }
</style>

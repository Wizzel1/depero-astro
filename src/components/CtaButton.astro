---
export interface Props {
    href: string;
    label: string;
}

const { href, label } = Astro.props;
---

<a href={href} class="cta-btn">{label}</a>

<style>
    .cta-btn {
        display: inline-block;
        padding: 14px 36px;
        border: 2px solid var(--dark);
        border-radius: 50px;
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 700;
        color: var(--dark);
        background: transparent;
        transition:
            background 0.3s,
            color 0.3s;
        text-align: center;
    }

    .cta-btn:hover {
        background: var(--dark);
        color: #fff;
    }
</style>
